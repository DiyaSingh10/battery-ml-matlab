%% task6 - Model Performance Evaluation
% PERFORMANCE METRICS FUNCTION
% This function computes:
% R2, RMSE, MAE
computeMetrics = @(Y, Ypred) struct( ...
    'RMSE', sqrt(mean((Y - Ypred).^2)), ...
    'MAE',  mean(abs(Y - Ypred)), ...
    'R2',   1 - sum((Y - Ypred).^2)/sum((Y - mean(Y)).^2) );

% CALCULATE METRICS FOR ANN
Md1_Train = computeMetrics(YTrain_ANN, YTrainPred_ANN);
Md1_Test  = computeMetrics(YTest_ANN,  YTestPred_ANN);
% CALCULATE METRICS FOR DECISION TREE
Md2_Train = computeMetrics(YTrain, YTrainPred);
Md2_Test  = computeMetrics(YTest,  YTestPred);
% CREATE COMPARISON TABLE
Model = string([ ...
    "ANN"
    "ANN"
    "Decision Tree"
    "Decision Tree" ]);

Dataset = string([ ...
    "Training"
    "Testing"
    "Training"
    "Testing" ]);

R2 = [ ...
    Md1_Train.R2; ...
    Md1_Test.R2; ...
    Md2_Train.R2; ...
    Md2_Test.R2];

RMSE = [ ...
    Md1_Train.RMSE; ...
    Md1_Test.RMSE; ...
    Md2_Train.RMSE; ...
    Md2_Test.RMSE];

MAE = [ ...
    Md1_Train.MAE; ...
    Md1_Test.MAE; ...
    Md2_Train.MAE; ...
    Md2_Test.MAE];

% Create table
ResultsTable = table(Model, Dataset, R2, RMSE, MAE);
ResultsTable.Model   = categorical(ResultsTable.Model);
ResultsTable.Dataset = categorical(ResultsTable.Dataset);
% DISPLAY RESULTS
disp('=============================================')
disp(' MODEL PERFORMANCE COMPARISON TABLE ')
disp('=============================================')
disp(ResultsTable)

