scatter(YTest_ANN, YTestPred_ANN, 30, 'filled')
hold on
plot([min(YTest_ANN) max(YTest_ANN)], ...
     [min(YTest_ANN) max(YTest_ANN)], ...
     'r--', 'LineWidth', 1.5)

xlabel('Actual Tavg')
ylabel('Predicted Tavg')
title('Testing Data')
grid on

