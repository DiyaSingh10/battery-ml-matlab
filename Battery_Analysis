%% task1 - Statistical Analysis of Variables
% Read data
T = readtable("BC_35.csv");
B = table2array(T);
varNames = T.Properties.VariableNames;
% Compute statistics (column-wise)
Mean      = mean(B);
Median    = median(B);
StdDev    = std(B);
Variance  = var(B);
Minimum   = min(B);
Maximum   = max(B);
Skewness  = skewness(B);
Kurtosis  = kurtosis(B);
% Put into one matrix
Stats = [Mean; Median; StdDev; Variance; Minimum; Maximum; Skewness; Kurtosis];
% Create table
Tab = array2table(Stats, ...
    'VariableNames', {'Mean','Median','StdDev','Variance','Min','Max','Skewness','Kurtosis'}, ...
    'RowNames', varNames);
% Display
disp('Statistical Analysis Results:');
disp(Tab);

%% task2 - Graphical Analysis (Histograms)
% Loop through each variable
for i = 1:length(varNames)
    % histogram plotting
    figure
    addID()
    histogram(rmmissing(B(:,i)));
    title(['Histogram of ', varNames{i}])
    xlabel(varNames{i})
    ylabel('Statistical Frequency')
    grid on
        statsText = sprintf([ ...
        'Mean = %.3f\n ' ...
        'Median = %.3f\n ' ...
        'StdDev = %.3f\n ' ...
        'Variance = %.3f\n' ...
        'Min = %.3f\n ' ...
        'Max = %.3f\n ' ...
        'Skewness = %.3f\n ' ...
        'Kurtosis = %.3f'], ...
         Mean(i), Median(i), StdDev(i), Variance(i), Minimum(i), Maximum(i), Skewness(i), Kurtosis(i));
    % Display statistics on plot
    text(0.99, 0.99, statsText, ...
    'Units','normalized', ...
    'HorizontalAlignment','right', ...
    'VerticalAlignment','top', ...
    'BackgroundColor','w', ...
    'EdgeColor','k', ...
    'Margin',5);
end

%% task3(A) - Correlation Analysis (Linear Correlation)
% Compute Pearson Correlation Matrix
R = corr(B, 'Type', 'Pearson');
% Plot Heatmap
figure('Name','Pearson Correlation Matrix','NumberTitle','off');
addID()
h = heatmap(varNames, varNames, R);
% Formatting
h.Title = 'Linear Pearson Correlation Matrix';
h.Colormap = cool;
h.ColorLimits = [-1 1];   % Correlation range
h.CellLabelFormat = '%.2f'; % Show values
h.MissingDataColor = [1 1 1];    
h.MissingDataLabel = 'NaN';     

%% task3(B) - Correlation Analysis (Non-Linear)
% Compute Spearman Correlation Matrix
R_spearman = corr(B, 'Type', 'Spearman');
% Plot Heatmap
figure('Name','Spearman Rank Correlation','NumberTitle','off');
addID()
h = heatmap(varNames, varNames, R);
% Formatting
h.Title = 'Non-linear Spearman Rank Correlation';
h.Colormap = cool;
h.ColorLimits = [-1 1];   % Correlation range
h.CellLabelFormat = '%.2f'; % Show values
h.MissingDataColor = [1 1 1];    
h.MissingDataLabel = 'NaN';     

%% task4 - Feature Selection for ML Modeling
%%Keep Only Numeric Variables
numericData = T(:, vartype('numeric'));
%Check if Tavg Exists
if ~ismember('Tavg', numericData.Properties.VariableNames)
    error('Tavg is not numeric or not found in the dataset.');
end

%%Separate Target and Inputs
% Target
Y = numericData(:,end);
% Inputs
X = removevars(numericData,'Tavg');
Xnames = X.Properties.VariableNames;
Z = table2array(X);

%%Correlation analysis
Z_numeric = Z;
Y_numeric = table2array(Y);
cv = corr(Z_numeric, Y_numeric, 'Rows','complete');

%%Statistical spread(Std Deviation)
stdv = std(Z);

%%Redundancy Removal
% Correlation between features
corrMatrix = corr(Z,'Rows','complete');
% Threshold for redundancy
rt = 0.85;

%%Domain Relevance
domainWeight = ones(length(Xnames));
for i = 1:length(Xnames)
    name = lower(Xnames{i});
    if contains(name,{'Mean','Median','StdDev','Variance','Min','Max','Skewness','Kurtosis'})
        domainWeight(i) = 1.5;   % More important
    else
        domainWeight(i) = 1.0;   % Normal importance
    end
end

%% task5 - Artificial Neural Network(ANN)
% Load Data 
% HoldOut Partition (80% Train, 20% Test)
c = cvpartition(height(T), "HoldOut", 0.20);
trainingIdx = training(c);
Train = T(trainingIdx, :);
testIdx = test(c);
Test = T(testIdx, :);
% Train ANN Model
% Artificial Neural Network Regression
Mdl = fitrnet(Train, "Tavg", ...
             "Standardize", true, ...
             "LayerSizes", [20 10], ...
             "Activations", "relu");

% Actual Outputs
YTrain_ANN = Train.Tavg;
YTest_ANN  = Test.Tavg;
% Predictions
YTrainPred_ANN = predict(Mdl, Train);
YTestPred_ANN  = predict(Mdl, Test);

%%Performance Evaluation:
% RMSE
Train_RMSE_ANN = sqrt(mean((YTrain_ANN - YTrainPred_ANN).^2));
Test_RMSE_ANN  = sqrt(mean((YTest_ANN  - YTestPred_ANN).^2));
% R2 (Training)
SS_res_ANN = sum((YTrain_ANN - YTrainPred_ANN).^2);
SS_tot_ANN = sum((YTrain_ANN - mean(YTrain_ANN)).^2);
R2_Train_ANN = 1 - (SS_res_ANN / SS_tot_ANN);
% Display Results
disp('=============================================')
disp(' ARTIFICIAL NEURAL NETWORK(ANN) ')
disp('=============================================')
fprintf('Training RMSE : %.4f\n', Train_RMSE_ANN);
fprintf('Testing RMSE  : %.4f\n', Test_RMSE_ANN);
fprintf('Training R^2  : %.4f\n', R2_Train_ANN);

%%Regression Plot:
figure
addID()
% Training Regression
subplot(1,2,1)
scatter(YTrain_ANN, YTrainPred_ANN, 30, 'filled')
hold on
plot([min(YTrain_ANN) max(YTrain_ANN)], ...
     [min(YTrain_ANN) max(YTrain_ANN)], ...
     'r--', 'LineWidth', 1.5)

xlabel('Actual Tavg')
ylabel('Predicted Tavg')
title('Training Data')
grid on

% Testing Regression
